<%# // Ephesians 4:28 - "Let the thief no longer steal, but rather let him labor..." %>
<%# // DISCLAIMER: This is a .RHTML (Ruby HTML / ERB) file used in Ruby on Rails views %>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Chris Die Kunstkatze</title>

  <!-- Main stylesheet -->
  <link rel="stylesheet" href="/assets/styles.css">

  <!-- Website icon -->
  <link rel="icon" type="image/x-icon" href="/assets/icon.ico">

  <!-- Custom font (for offline use)
       Place font file in /assets/fonts/ and update name below -->
  <style>
    @font-face {
      font-family: 'CustomFont';
      src: url('/assets/fonts/custom-font.woff2') format('woff2');
    }
  </style>

  <!-- Custom cursor (mouse icon)
       Replace file path with your .cur or .png file -->
  <style>
    body {
      cursor: url('/assets/cursor.cur'), auto;
    }
  </style>

  <!-- Security Meta Tags -->
  <meta http-equiv="X-Content-Type-Options" content="nosniff">
  <meta http-equiv="X-Frame-Options" content="DENY">
  <meta http-equiv="X-XSS-Protection" content="1; mode=block">
  <meta name="referrer" content="no-referrer-when-downgrade">

  <!-- Allow crawlers but discourage indexing of sensitive parts -->
  <meta name="robots" content="index, follow">

</head>

<body>

  <!-- Header -->
  <header class="main-header">
    <div class="logo">
      <!-- Add your logo image here -->
      <img src="/assets/logo.png" alt="Logo">
    </div>

    <h1>Chris Die Kunstkatze</h1>

    <nav>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/blogs">Blogs</a></li>
      </ul>
    </nav>
  </header>

  <!-- Main Content -->
  <main>
    <section class="intro">
      <h2>Welcome to the Blog</h2>
      <p>Thoughts, creativity, and expression all in one place.</p>
    </section>

    <section class="blog-list">
      <!-- Blog posts will be rendered here -->
      <%= yield %>
    </section>
  </main>

  <!-- Footer -->
  <footer>
    <p>© <%= Time.now.year %> Chris Die Kunstkatze</p>
  </footer>

  <!-- Anti-Inspect Script (discouragement only) -->
  <script>
    (function() {
      const isBot = /bot|crawler|spider|crawling/i.test(navigator.userAgent);

      if (!isBot) {
        document.addEventListener('contextmenu', e => e.preventDefault());

        document.onkeydown = function(e) {
          if (
            e.key === "F12" ||
            (e.ctrlKey && e.shiftKey && ["I","J","C"].includes(e.key)) ||
            (e.ctrlKey && e.key === "U")
          ) {
            return false;
          }
        };

        setInterval(function() {
          const devtools = /./;
          devtools.toString = function() {
            document.body.innerHTML = "Inspection Disabled";
          };
          console.log(devtools);
        }, 1000);
      }
    })();
  </script>

  <!-- .CHM File Integration Placeholder -->
  <%# 
    .CHM FILE (Compiled HTML Help File)
    Purpose: Offline documentation or help system

    To use:
    1. Place your file in /public/help/help.chm
    2. Link it like below:
  %>

  <a href="/help/help.chm" download>Download Help File</a>

</body>
</html>